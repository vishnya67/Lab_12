def bubble_sort_optimized(arr):
    n = len(arr)
    iterations = 0
    
    for i in range(n):
        iterations += 1
        swapped = False
        for j in range(0, n - i - 1):
            if arr[j] > arr[j + 1]:
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
                swapped = True
        if not swapped:
            break
            
    return arr, iterations
