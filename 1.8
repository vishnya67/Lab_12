def binary_search_steps(arr, target):
    steps = []
    low = 0
    high = len(arr) - 1
    
    while low <= high:
        mid = (low + high) // 2
        steps.append(mid)
        
        if arr[mid] == target:
            return (steps, mid)
        elif arr[mid] < target:
            low = mid + 1
        else:
            high = mid - 1
            
    return (steps, -1)
